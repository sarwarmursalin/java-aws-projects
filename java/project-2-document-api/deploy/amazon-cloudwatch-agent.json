{
  "agent": {
    "metrics_collection_interval": 60
  },
  "metrics": {
    "metrics_collected": {
      "mem": {
        "measurement": ["mem_used_percent"]
      }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/document-api.log",
            "log_group_name": "document-api-logs",
            "log_stream_name": "{instance_id}"
          }
        ]
      }
    }
  }
}
